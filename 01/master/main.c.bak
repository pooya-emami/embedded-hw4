#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sqlite3.h>
#include <curl/curl.h>
#include <mongoose.h>

#define MAX_RESPONSE 4096
#define MAX_LINE 256

// Configuration structure
typedef struct {
    int port;
    char db_path[256];
    char slave1_ip[64];
    int slave1_port;
    char slave2_ip[64];
    int slave2_port;
} Config;

Config config;

// Read config file
void read_config(const char *filename) {
    FILE *file = fopen(filename, "r");
    if (!file) {
        fprintf(stderr, "Warning: Could not open %s, using defaults\n", filename);
        return;
    }
    
    char line[MAX_LINE];
    while (fgets(line, sizeof(line), file)) {
        if (line[0] == '#' || line[0] == '\n') continue;
        
        char key[64], value[256];
        if (sscanf(line, "%[^=]=%s", key, value) == 2) {
            // Remove newline from value
            value[strcspn(value, "\n")] = 0;
            
            if (strcmp(key, "MASTER_PORT") == 0) config.port = atoi(value);
            else if (strcmp(key, "MASTER_DB") == 0) strcpy(config.db_path, value);
            else if (strcmp(key, "SLAVE1_IP") == 0) strcpy(config.slave1_ip, value);
            else if (strcmp(key, "SLAVE1_PORT") == 0) config.slave1_port = atoi(value);
            else if (strcmp(key, "SLAVE2_IP") == 0) strcpy(config.slave2_ip, value);
            else if (strcmp(key, "SLAVE2_PORT") == 0) config.slave2_port = atoi(value);
        }
    }
    fclose(file);
}

struct callback_data {
    char *response;
    size_t size;
};

static size_t write_callback(void *contents, size_t size, size_t nmemb, void *userp) {
    size_t total_size = size * nmemb;
    struct callback_data *data = (struct callback_data *)userp;
    data->response = realloc(data->response, data->size + total_size + 1);
    memcpy(&(data->response[data->size]), contents, total_size);
    data->size += total_size;
    data->response[data->size] = 0;
    return total_size;
}

static char *query_slave(const char *ip, int port, const char *sensor_type, const char *sensor_id) {
    CURL *curl;
    CURLcode res;
    struct callback_data data = {NULL, 0};
    char url[256];
    
    snprintf(url, sizeof(url), "http://%s:%d/query?sensor_type=%s&sensor_id=%s", 
             ip, port, sensor_type, sensor_id);
    
    curl = curl_easy_init();
    if (!curl) return NULL;
    
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &data);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT, 5L);
    
    res = curl_easy_perform(curl);
    curl_easy_cleanup(curl);
    
    if (res != CURLE_OK) {
        free(data.response);
        return NULL;
    }
    return data.response;
}

static char *query_local_db(const char *db_path, const char *sensor_type, const char *sensor_id) {
    sqlite3 *db;
    sqlite3_stmt *stmt;
    char *result = NULL;
    char sql[512];
    
    if (sqlite3_open(db_path, &db) != SQLITE_OK) {
        return NULL;
    }
    
    snprintf(sql, sizeof(sql), 
             "SELECT s.sensor_id, s.sensor_type, s.sensor_name, r.value, s.unit, r.recorded_at "
             "FROM sensors s JOIN sensor_readings r ON s.sensor_id = r.sensor_id "
             "WHERE s.sensor_type = '%s' AND s.sensor_id = '%s' "
             "ORDER BY datetime(r.recorded_at) DESC LIMIT 1",
             sensor_type, sensor_id);
    
    if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW) {
            result = malloc(512);
            snprintf(result, 512, 
                     "{\"sensor_id\":\"%s\",\"sensor_type\":\"%s\",\"sensor_name\":\"%s\","
                     "\"value\":\"%s\",\"unit\":\"%s\",\"recorded_at\":\"%s\"}",
                     sqlite3_column_text(stmt, 0),
                     sqlite3_column_text(stmt, 1),
                     sqlite3_column_text(stmt, 2),
                     sqlite3_column_text(stmt, 3),
                     sqlite3_column_text(stmt, 4),
                     sqlite3_column_text(stmt, 5));
        }
        sqlite3_finalize(stmt);
    }
    sqlite3_close(db);
    return result;
}

static void http_handler(struct mg_connection *c, int ev, void *ev_data) {
    if (ev == MG_EV_HTTP_MSG) {
        struct mg_http_message *hm = (struct mg_http_message *)ev_data;
        
        if (mg_strcmp(hm->uri, mg_str("/query")) == 0) {
            char sensor_type[64], sensor_id[64];
            mg_http_get_var(&hm->query, "sensor_type", sensor_type, sizeof(sensor_type));
            mg_http_get_var(&hm->query, "sensor_id", sensor_id, sizeof(sensor_id));
            
            char *response = query_local_db(config.db_path, sensor_type, sensor_id);
            
            if (!response) {
                char *slave1_resp = query_slave(config.slave1_ip, config.slave1_port, 
                                                sensor_type, sensor_id);
                if (slave1_resp) {
                    response = slave1_resp;
                } else {
                    char *slave2_resp = query_slave(config.slave2_ip, config.slave2_port, 
                                                    sensor_type, sensor_id);
                    if (slave2_resp) {
                        response = slave2_resp;
                    }
                }
            }
            
            if (response) {
                mg_http_reply(c, 200, "Content-Type: application/json\r\n", "%s", response);
                free(response);
            } else {
                mg_http_reply(c, 404, "Content-Type: application/json\r\n", 
                             "{\"error\":\"Sensor data not found\"}");
            }
        }
    }
}

int main(int argc, char *argv[]) {
    // Set defaults
    config.port = 8080;
    strcpy(config.db_path, "master.db");
    strcpy(config.slave1_ip, "127.0.0.1");
    config.slave1_port = 8081;
    strcpy(config.slave2_ip, "127.0.0.1");
    config.slave2_port = 8082;
    
    if (argc >= 2) {
        read_config(argv[1]);
    } else {
        read_config("config.example");
    }
    
    struct mg_mgr mgr;
    mg_mgr_init(&mgr);
    
    char addr[32];
    snprintf(addr, sizeof(addr), "http://0.0.0.0:%d", config.port);
    mg_http_listen(&mgr, addr, http_handler, NULL);
    
    printf("Master server running on port %d\n", config.port);
    
    while (1) {
        mg_mgr_poll(&mgr, 1000);
    }
    
    mg_mgr_free(&mgr);
    return 0;
}